#!/bin/sh
set -e

case "$1" in
    configure)
        # Service account. Created once; intentionally never removed on
        # remove/purge (files may remain owned by it, and UID reuse is a
        # security risk).
        if ! getent passwd cloudflare-ddns >/dev/null; then
            adduser --system --group --no-create-home \
                --home /var/lib/cloudflare-register \
                --shell /usr/sbin/nologin \
                --gecos 'cloudflare-register service account' \
                cloudflare-ddns
        fi

        for dir in /var/lib/cloudflare-register /var/log/cloudflare-register; do
            if [ ! -d "$dir" ]; then
                mkdir -p "$dir"
            fi
            chown cloudflare-ddns:cloudflare-ddns "$dir"
            chmod 0750 "$dir"
        done

        # Do not generate config (or secrets) here; the CLI does that.
        if [ ! -f /etc/cloudflare-register.json ]; then
            echo "No /etc/cloudflare-register.json found."
            echo "Run 'cloudflare-register init --system' to create it, then:"
            echo "    systemctl restart cloudflare-ddns"
        fi
    ;;
esac

#DEBHELPER#

exit 0
