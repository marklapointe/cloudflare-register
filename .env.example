# --------------------------------------------------------------------------
# cloudflare-register runtime configuration.
# Copy this file to `.env` and fill in the required values.
# Production secrets MUST live in a file with 0600 permissions.
# --------------------------------------------------------------------------

# Base paths. These respect XDG when set, falling back to ~/.local/share/cloudflare_register/
# Override only if you want non-standard locations (e.g. for service packaging).
# XDG_DATA_HOME=/var/lib
# XDG_CONFIG_HOME=/etc
# XDG_CACHE_HOME=/var/cache

# --- Provider ---
# Currently only "cloudflare" is implemented; this is intentionally extensible.
DNS_PROVIDER=cloudflare

# Cloudflare API token (required). Create at:
#   https://dash.cloudflare.com/profile/api-tokens
# Scope: Zone:DNS:Edit on the zones you want to manage
CLOUDFLARE_API_TOKEN=replace_me

# --- Web UI ---
# Bind address for the FastAPI service.
HTTP_HOST=127.0.0.1
HTTP_PORT=8000

# Admin credentials (REQUIRED for first run).
# Generate a strong password; rotate regularly.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_me

# JWT signing secret. MUST be a long random string (>= 32 bytes).
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=replace_me_with_output_of_secrets_token_urlsafe_48

ACCESS_TOKEN_EXPIRE_MINUTES=60

# Set to "true" to mark the session cookie Secure (HTTPS only).
# Leave "false" for local HTTP development.
COOKIE_SECURE=false

# --- Sync loop ---
# Seconds between sync cycles (when run as a service). Default 300.
SYNC_INTERVAL_SECONDS=300

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
