#!/usr/bin/env bash
# Secret guard: refuses to commit anything that smells like a credential.
#
# Checks the staged diff (vs HEAD) and the working tree for common secret
# patterns: Cloudflare API tokens, AWS keys, generic high-entropy strings
# inside config-shaped lines, and the project's own test-token placeholder
# escaping from fixtures.

set -eu

PATTERNS=(
  # Cloudflare API tokens: cfut_ followed by 40 hex chars (project's real prefix)
  '(^|[[:space:]])(cfut_[A-Za-z0-9_-]{20,})'
  # AWS access key IDs
  'AKIA[0-9A-Z]{16}'
  # Generic private key blocks
  '-----BEGIN (RSA |EC |OPENSSH |DSA |PGP )?PRIVATE KEY-----'
  # GitHub personal access tokens (ghp_, ghs_, gho_, ghu_, ghr_)
  '(^|[[:space:]])(ghp_|ghs_|gho_|ghu_|ghr_)[A-Za-z0-9]{20,}'
  # Generic bearer tokens / Slack tokens
  'xox[baprs]-[0-9A-Za-z-]{10,}'
)

FAIL=0
STAGED=$(git diff --cached --diff-filter=ACMR --unified=0 || true)
WORKING=$(git diff --unified=0 || true)
NEW_FILES=$(git ls-files --others --exclude-standard || true)

scan() {
  local label="$1"
  local hay="$2"
  for pat in "${PATTERNS[@]}"; do
    if grep -nE "$pat" <<<"$hay" >/tmp/secret-scan.out 2>/dev/null; then
      echo "BLOCKED: pattern $pat matched in $label"
      sed 's/^/    /' /tmp/secret-scan.out
      FAIL=1
    fi
  done
}

if [[ -n "$STAGED" ]]; then
  scan "staged diff" "$STAGED"
fi
if [[ -n "$WORKING" ]]; then
  scan "working diff" "$WORKING"
fi
if [[ -n "$NEW_FILES" ]]; then
  # Only scan small files; large binaries are already gitignored.
  for f in $NEW_FILES; do
    [[ -f "$f" ]] || continue
    if [[ $(wc -c <"$f") -gt 1048576 ]]; then continue; fi
    if file --mime-type "$f" | grep -qv 'text/'; then continue; fi
    if content=$(cat "$f") && [[ -n "$content" ]]; then
      scan "new file: $f" "$content"
    fi
  done
fi

if [[ $FAIL -ne 0 ]]; then
  echo ""
  echo "If this is a false positive, unstage the offending line or file and re-run."
  exit 1
fi

echo "secret-scan: clean"
exit 0
