#!/usr/bin/env bash
# Secret guard: refuses to commit anything that smells like a credential.
#
# Blocks on the staged diff and untracked files; the unstaged working diff
# only warns (it isn't part of the commit). Patterns cover Cloudflare API
# token assignments, AWS keys, private key blocks, GitHub and Slack tokens.

set -eu

PATTERNS=(
  # Real Cloudflare API tokens have no fixed prefix, so match config-shaped
  # assignments to the token key with a plausible token value instead.
  '[Cc][Ll][Oo][Uu][Dd][Ff][Ll][Aa][Rr][Ee]_[Aa][Pp][Ii]_[Tt][Oo][Kk][Ee][Nn]["'"'"']?[[:space:]]*[:=][[:space:]]*["'"'"']?[A-Za-z0-9_-]{30,}'
  # Legacy project-internal cfut_ style tokens
  '(^|[[:space:]])(cfut_[A-Za-z0-9_-]{20,})'
  # AWS access key IDs
  'AKIA[0-9A-Z]{16}'
  # Generic private key blocks
  '-----BEGIN (RSA |EC |OPENSSH |DSA |PGP )?PRIVATE KEY-----'
  # GitHub personal access tokens (ghp_, ghs_, gho_, ghu_, ghr_)
  '(^|[[:space:]])(ghp_|ghs_|gho_|ghu_|ghr_)[A-Za-z0-9]{20,}'
  # Generic bearer tokens / Slack tokens
  'xox[baprs]-[0-9A-Za-z-]{10,}'
)

FAIL=0
WARN=0
SCAN_OUT=$(mktemp "${TMPDIR:-/tmp}/secret-scan.XXXXXX")
trap 'rm -f "$SCAN_OUT"' EXIT

STAGED=$(git diff --cached --diff-filter=ACMR --unified=0 || true)
WORKING=$(git diff --unified=0 || true)

scan() {
  # scan <block|warn> <label> <haystack>
  local mode="$1"
  local label="$2"
  local hay="$3"
  for pat in "${PATTERNS[@]}"; do
    if grep -nE "$pat" <<<"$hay" >"$SCAN_OUT" 2>/dev/null; then
      if [[ "$mode" == block ]]; then
        echo "BLOCKED: pattern $pat matched in $label"
        FAIL=1
      else
        echo "WARNING: pattern $pat matched in $label (not staged; commit not blocked)"
        WARN=1
      fi
      sed 's/^/    /' "$SCAN_OUT"
    fi
  done
}

if [[ -n "$STAGED" ]]; then
  scan block "staged diff" "$STAGED"
fi
if [[ -n "$WORKING" ]]; then
  scan warn "working diff" "$WORKING"
fi
# Only scan small text files; large binaries are already gitignored.
while IFS= read -r f; do
  [[ -n "$f" && -f "$f" ]] || continue
  if [[ $(wc -c <"$f") -gt 1048576 ]]; then continue; fi
  if file --mime-type "$f" | grep -qv 'text/'; then continue; fi
  if content=$(cat "$f") && [[ -n "$content" ]]; then
    scan block "new file: $f" "$content"
  fi
done < <(git ls-files --others --exclude-standard || true)

if [[ $FAIL -ne 0 ]]; then
  echo ""
  echo "If this is a false positive, unstage the offending line or file and re-run."
  exit 1
fi

if [[ $WARN -ne 0 ]]; then
  echo "secret-scan: staged content clean (warnings above are unstaged)"
else
  echo "secret-scan: clean"
fi
exit 0
